{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/map", "destination": "/pages/map.html" },
    { "source": "/login", "destination": "/pages/login.html" },
    { "source": "/register", "destination": "/pages/register.html" },
    { "source": "/admin", "destination": "/pages/admin.html" },
    { "source": "/pending", "destination": "/pages/pending.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}